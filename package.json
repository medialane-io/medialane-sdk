{
  "name": "@medialane/sdk",
  "version": "0.6.6",
  "description": "Framework-agnostic TypeScript SDK for Medialane.io — the IP marketplace on Starknet",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "starknet": ">=6.0.0"
  },
  "devDependencies": {
    "starknet": "^6.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
